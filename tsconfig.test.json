{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "src/lib/**/*.ts",
    "src/types/**/*.ts",
    "src/schemas/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
